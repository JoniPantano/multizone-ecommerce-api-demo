PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:password@localhost:5432/MultiZona_DB

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=1d

PUBLIC_API_URL=
CORS_ORIGIN=*
CORS_ALLOWED_ORIGINS=
EXPOSE_VERIFICATION_CODE=false

MAX_VERIFICATION_REQUESTS=4
VERIFICATION_REQUEST_WINDOW_MS=60000

RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=

MIGRATE_RETRY_ATTEMPTS=8
MIGRATE_RETRY_DELAY_MS=5000

MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_WEBHOOK_URL=
MP_SUCCESS_URL=
MP_FAILURE_URL=
MP_PENDING_URL=
MP_CURRENCY=ARS
MP_API_BASE_URL=https://api.mercadopago.com
MP_EXCLUDED_PAYMENT_TYPE_IDS=ticket,atm
MP_EXCLUDED_PAYMENT_METHOD_IDS=

ORDER_IDEMPOTENCY_TTL_HOURS=24
ORDER_PENDING_TTL_MINUTES=60

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50
ORDER_RATE_LIMIT_WINDOW_MS=300000
ORDER_RATE_LIMIT_MAX=60
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=120
